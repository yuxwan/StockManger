{
  "name": "desktop-app",
  "version": "1.0.0",
  "description": "Electron + Vue3 desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.desktop.pos",
    "productName": "Stock",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*"
    ]
  },
  "dependencies": {
    "@iconify/vue": "^4.3.0",
    "@vuepic/vue-datepicker": "^14.0.0",
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "jsbarcode": "^3.12.3",
    "naive-ui": "^2.44.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0"
  }
}
