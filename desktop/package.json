{
  "name": "desktop-app",
  "version": "1.0.13",
  "description": "Stock",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.desktop.pos",
    "productName": "Stock",
    "directories": {
      "output": "release"
    },
    "win": {
      "artifactName": "Stock.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://yuxwan.com/download/stock/",
        "channel": "latest"
      }
    ],
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/electron-updater/**"
    ]
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.87",
    "@iconify/vue": "^4.3.0",
    "@vuepic/vue-datepicker": "^14.0.0",
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "electron-updater": "^6.8.9",
    "jsbarcode": "^3.12.3",
    "naive-ui": "^2.44.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0"
  }
}
